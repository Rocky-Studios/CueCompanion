@page "/config"
@using CueCompanion.Components.Dashboard
@inject AuthService AuthService

<PageTitle>Config - Cue Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudText Typo="Typo.h1">Config</MudText>
    @if (AuthService.User == null)
    {
        <MudAlert Severity="Severity.Error">You must be logged in to access the config page.</MudAlert>
    }
    else
    {
        @if (!_hasPermission)
        {
            <MudAlert Severity="Severity.Error">Access denied.</MudAlert>
        }

        @if (_hasPermission)
        {
            <PanelContainer>

            </PanelContainer>
        }
    }
</MudContainer>

@code
{
    private bool _hasPermission;

    protected override Task OnInitializedAsync()
    {
        try
        {
            AuthService.OnStateChanged += () =>
                                          {
                                              _hasPermission = AuthService.User != null && AuthService.HasPermission("Admin");

                                              InvokeAsync(StateHasChanged);
                                          };
            return Task.CompletedTask;
        }
        catch (Exception exception)
        {
            return Task.FromException(exception);
        }
    }
}
