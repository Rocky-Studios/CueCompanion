@page "/config"
@using CueCompanion.Components.Config
@using CueCompanion.Components.Dashboard
@inject AuthService           AuthService
@inject ConfigService         ConfigService
@inject UserManagementService UserManagement
@inject SimpleDialogService   Dialogs

<PageTitle>Config - Cue Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    @if (AuthService.User == null)
    {
        <MudAlert Severity="Severity.Error">You must be logged in to access the config page.</MudAlert>
    }
    else
    {
        @if (!_hasPermission)
        {
            <MudAlert Severity="Severity.Error">Access denied.</MudAlert>
        }

        @if (_hasPermission)
        {
            <PanelContainer>
                <CascadingValue TValue="ConfigService" Value="ConfigService">
                    <CascadingValue TValue="UserManagementService" Value="UserManagement">
                        <CascadingValue TValue="AuthService" Value="AuthService">
                            <SessionManager/>
                        </CascadingValue>
                    </CascadingValue>
                </CascadingValue>
            </PanelContainer>
        }
    }
</MudContainer>

@code
{
    [CascadingParameter]
    public UserProvider? UserProvider { get; set; }

    private bool _hasPermission;

    protected override Task OnInitializedAsync()
    {
        AuthService.OnStateChanged += async () =>
        {
            _hasPermission = AuthService.User != null && AuthService.HasPermission("Admin");

            if (_hasPermission && AuthService.ApiKey is { } key)
            {
                _ = ConfigService.GetApiKeys(key);
                var r = await UserManagement.GetUsers(key);
                UserManagement.UserInfos = r.GetValue(s => Dialogs.Show("Failed to retrieve users", s));
            }

            await InvokeAsync(StateHasChanged);
        };
        ConfigService.OnStateChanged += async () =>
        {
            if (_hasPermission && AuthService.ApiKey is { } key)
            {
                _ = ConfigService.GetApiKeys(key);
            }

            await InvokeAsync(StateHasChanged);
        };

        UserManagement.OnStateChanged += async () =>
        {
            if (_hasPermission && AuthService.ApiKey is { } key)
            {
                var r = await UserManagement.GetUsers(key);
                UserManagement.UserInfos = r.GetValue(s => Dialogs.Show("Failed to retrieve users", s));
            }

            await InvokeAsync(StateHasChanged);
        };
        _ = ConfigService.StartAsync(Navigation.BaseUri);
        _ = UserManagement.StartAsync(Navigation.BaseUri, UserProvider!);
        return Task.CompletedTask;
    }
}
