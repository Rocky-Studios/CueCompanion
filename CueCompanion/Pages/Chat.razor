@page "/chat"
@inject AuthService         AuthService
@inject ChatService         ChatService
@inject SimpleDialogService Dialogs
@inject IJSRuntime          Js
@implements IAsyncDisposable

<PageTitle>Chat - Cue Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudText Typo="Typo.h1">Chat</MudText>
    @if (AuthService.User == null)
    {
        <MudText>You must be logged in to view the chat.</MudText>
    }
    else
    {
        @if (!_hasViewPermission)
        {
            <MudAlert Severity="Severity.Error">Access denied.</MudAlert>
        }
        else
        {
            <div @ref="_messagesContainer" style="max-height: 60vh; overflow-y: auto;">
                <MudPaper Class="p-4">
                    @foreach (Message message in ChatService.Messages)
                    {
                        ChatService.UserIdToNameCache.TryGetValue(message.Sender, out string? sender);
                        <MudText>
                            <b>@sender:</b> @message.Content
                        </MudText>
                    }
                </MudPaper>
            </div>
            @if (_hasTypePermission)
            {
                <MudTextField @bind-Value="@_messageContent"></MudTextField>
                <MudButton EndIcon="@Icons.Material.Filled.Send" OnClick="@OnSendButtonClicked">Send</MudButton>
            }
        }

    }
</MudContainer>

@code
{
    private string?          _messageContent;
    private ElementReference _messagesContainer;
    private bool             _shouldScrollToBottom;
    private Action?          _authStateChangedHandler;
    private Action?          _chatStateChangedHandler;


    private bool _hasViewPermission, _hasTypePermission;


    protected override async Task OnInitializedAsync()
    {
        _authStateChangedHandler = AuthServiceOnOnStateChanged();
        _chatStateChangedHandler = ChatServiceOnOnStateChanged();

        if (AuthService != null) AuthService.OnStateChanged += _authStateChangedHandler;
        if (ChatService != null) ChatService.OnStateChanged += _chatStateChangedHandler;

        if (ChatService != null) await ChatService.StartAsync(Navigation.BaseUri);
        _shouldScrollToBottom = true;


        AuthService!.OnStateChanged += () =>
                                      {
                                          if (AuthService.User != null)
                                          {
                                              _hasViewPermission = AuthService.HasPermission("ViewChat");
                                              _hasTypePermission = AuthService.HasPermission("TypeChat");
                                          }
                                          else
                                          {
                                              _hasViewPermission = false;
                                              _hasTypePermission = false;
                                          }

                                          InvokeAsync(StateHasChanged);
                                      };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_shouldScrollToBottom) return;

        _shouldScrollToBottom = false;
        await Js.InvokeVoidAsync("cueCompanionChat.scrollToBottom", _messagesContainer);
    }

    private Action AuthServiceOnOnStateChanged()
    {
        return () =>
               {
                   InvokeAsync(StateHasChanged);
                   if (AuthService.SessionKey is { } key) ChatService?.GetAllMessages(key);
                   _shouldScrollToBottom = true;
               };
    }

    private Action ChatServiceOnOnStateChanged()
    {
        return () => _ = HandleChatStateChangedAsync();
    }

    private async Task HandleChatStateChangedAsync()
    {
        Message[] messages = ChatService.Messages.ToArray();
        foreach (Message message in messages)
        {
            if (!ChatService.UserIdToNameCache.ContainsKey(message.Sender))
            {
                User? user = (await AuthService?.GetUserAsync(message.Sender)!).Value;
                if (user != null)
                {
                    ChatService.UserIdToNameCache[message.Sender] = user.UserName;
                }
            }
        }

        _shouldScrollToBottom = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSendButtonClicked()
    {
        if (!_hasTypePermission)
        {
            _ = Dialogs.ShowError("Permission denied", "You do not have permission to send messages in the chat.");
            return;
        }

        if (!string.IsNullOrEmpty(_messageContent) && AuthService.SessionKey is { } key)
        {
            if (ChatService != null) await ChatService.SendMessage(key, _messageContent);
            _messageContent       = string.Empty;
            _shouldScrollToBottom = true;
        }
    }


    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (AuthService != null && _authStateChangedHandler != null) AuthService.OnStateChanged -= _authStateChangedHandler;
        if (ChatService != null && _chatStateChangedHandler != null) ChatService.OnStateChanged -= _chatStateChangedHandler;
        if (ChatService != null) await ChatService.DisposeAsync();
    }
}
