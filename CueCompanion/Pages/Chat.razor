@page "/chat"
@inject AuthService         AuthService
@inject ChatService         ChatService
@inject SimpleDialogService Dialogs
@implements IAsyncDisposable

<PageTitle>Chat - Cue Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudText Typo="Typo.h1">Chat</MudText>
    @if (AuthService.User == null)
    {
        <MudText>You must be logged in to view the chat.</MudText>
    }
    else
    {
        <MudPaper Class="p-4">
            <MudText Typo="Typo.h6">Chat Messages</MudText>
            @foreach (Message message in ChatService.Messages)
            {
                ChatService.UserIdToNameCache.TryGetValue(message.Sender, out string? sender);
                <MudText>
                    <b>@sender:</b> @message.Content
                </MudText>
            }

        </MudPaper>
        <MudPaper Class="p-4">
            <MudText Typo="Typo.h6">Send</MudText>
            <MudTextField @bind-Value="@messageContent"></MudTextField>
            <MudButton EndIcon="@Icons.Material.Filled.Send" OnClick="@OnSendButtonClicked">Send</MudButton>

        </MudPaper>
    }
</MudContainer>

@code
{
    //TODO send message box intersects navigation in mobile mode
    //TODO messages can unnecessarily make the document longer than the viewport
    private string? messageContent;

    protected override async Task OnInitializedAsync()
    {
        AuthService?.OnStateChanged += AuthServiceOnOnStateChanged();
        ChatService?.OnStateChanged += ChatServiceOnOnStateChanged();

        ChatService?.StartAsync(Navigation.BaseUri);
    }

    private Action? AuthServiceOnOnStateChanged()
    {
        return () =>
               {
                   InvokeAsync(StateHasChanged);
                   if (AuthService.SessionKey is { } key) ChatService?.GetAllMessages(key);
               };
    }

    private Action? ChatServiceOnOnStateChanged()
    {
        return async () =>
               {
                   Message[] messages = ChatService.Messages.ToArray();
                   foreach (Message message in messages)
                   {
                       if (!ChatService.UserIdToNameCache.ContainsKey(message.Sender))
                       {
                           User? user = (await AuthService?.GetUserAsync(message.Sender)!).Value;
                           if (user != null)
                           {
                               ChatService.UserIdToNameCache[message.Sender] = user.UserName;
                           }
                       }
                   }

                   await InvokeAsync(StateHasChanged);
               };
    }

    private void OnSendButtonClicked()
    {
        if (!string.IsNullOrEmpty(messageContent) && AuthService.SessionKey is { } key)
        {
            ChatService?.SendMessage(key, messageContent);
            messageContent = string.Empty;
        }
    }


    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (AuthService != null) AuthService.OnStateChanged -= AuthServiceOnOnStateChanged();
        if (ChatService != null) ChatService.OnStateChanged -= ChatServiceOnOnStateChanged();
        if (ChatService != null) await ChatService.DisposeAsync();
    }
}
