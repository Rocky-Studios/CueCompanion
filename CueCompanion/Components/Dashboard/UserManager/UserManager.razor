@using CueCompanion.UserManagement
@implements IAsyncDisposable

@inject AuthService           Auth
@inject UserManagementService UserManagement
@inject SimpleDialogService   Dialogs

@if (UserProvider?.CurrentUser != null && HasPermissions)
{
    <Panel>
        <MudText Typo="Typo.h2">User Manager</MudText>
        <MudCard Elevation="10" Style="max-height: 40vh; overflow-y: auto;">
            <MudTable Items="UserManagement.UserInfos" Dense="true" Elevation="0">
                <ColGroup>
                    <col style="width: 12.5%;"/>
                    <col style="width: 15%;"/>
                    <col style="width: 45%;"/>
                    <col style="width: 50%;"/>
                </ColGroup>
                <HeaderContent>
                    <MudTh>User ID</MudTh>
                    <MudTh>Username</MudTh>
                    <MudTh>Permissions</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.UserID</MudTd>
                    <MudTd>@context.UserName</MudTd>
                    <MudTd Class="permissions-cell">
                        <div class="permissions-container">
                            @foreach (string perm in GetPermissionsString(context).Split(", "))
                            {
                                @if (perm == "") continue;
                                <MudCard Class="d-inline" Style="padding: 0.1rem">
                                    @perm
                                    <MudTooltip Text="Remove permission">
                                        <MudIconButton Class="d-inline p-0" Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Small"
                                                       OnClick="@(() => { RemovePermissionFromUser(context.UserID, perm); })"/>
                                    </MudTooltip>
                                </MudCard>
                            }
                            @if (PermissionsNotAdded(context.Permissions).Length != 0)
                            {
                                <MudMenu Dense="true" Style="padding: 0;">
                                    <ActivatorContent Context="activatorContext">
                                        <MudTooltip Text="Add permission...">
                                            <MudIconButton Size="Size.Small" OnClick="@activatorContext.ToggleAsync"
                                                           Icon="@Icons.Material.Filled.Add"/>
                                        </MudTooltip>
                                    </ActivatorContent>
                                    <ChildContent>
                                        @foreach (string perm in PermissionsNotAdded(context.Permissions))
                                        {
                                            <MudMenuItem Label="@perm"
                                                         @onclick="@(() => { AddPermissionToUser(context.UserID, perm); })"/>
                                        }
                                    </ChildContent>
                                </MudMenu>
                            }
                        </div>
                    </MudTd>
                    <MudTd>
                        @if (context.UserName != "admin")
                        {
                            <MudTooltip Text="Edit username">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                               OnClick="@(() => OpenUsernameChangeDialog(context))"/>
                            </MudTooltip>
                        }
                        @if (context.UserName != "admin")
                        {
                            @if (context.CanLogin)
                            {
                                <MudTooltip Text="Logging in enabled">
                                    <MudIconButton Icon="@Icons.Material.Filled.Person" Color="Color.Primary"
                                                   OnClick="@(() => { DisableLoggingIn(context.UserID); })"/>
                                </MudTooltip>
                            }
                            else
                            {
                                <MudTooltip Text="Logging in disabled">
                                    <MudIconButton Icon="@Icons.Material.Filled.PersonOff" Color="Color.Primary"
                                                   OnClick="@(() => { EnableLoggingIn(context.UserID); })"/>
                                </MudTooltip>
                            }
                        }
                        @if (context.UserName != "admin")
                        {
                            <MudTooltip Text="Delete">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Primary"
                                               OnClick="@(() => { DeleteUser(context.UserID); })"/>
                            </MudTooltip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCard>
        <MudDialog @bind-Visible="_isEditUsernameDialogOpen" Options="new DialogOptions { CloseOnEscapeKey = true }">
            <TitleContent>
                Edit username
            </TitleContent>
            <DialogContent>
                <MudTextField Label="New username" @bind-Value="_editingUserName" Immediate="true" AutoFocus="true"/>
            </DialogContent>
            <DialogActions>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           OnClick="@UsernameChangeDialogCancelButtonPressed">Cancel
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@UsernameChangeDialogConfirmButtonPressed">Confirm
                </MudButton>
            </DialogActions>
        </MudDialog>
        <br/>
        <CreateNewUserForm/>
    </Panel>
}

@code
{
    [CascadingParameter]
    public UserProvider? UserProvider { get; set; }

    private int?   _editingUserId;
    private string _editingUserName         = string.Empty;
    private string _editingOriginalUserName = string.Empty;
    private bool   _isEditUsernameDialogOpen;

    private Action? _stateChangeHandler;

    protected override Task OnInitializedAsync()
    {
        UserManagement.OnStateChanged += async () =>
                                         {
                                             if (HasPermissions && Auth.ApiKey is { } key)
                                             {
                                                 var r = await UserManagement.GetUsers(key);
                                                 UserManagement.UserInfos = r.GetValue(s => Dialogs.ShowError("Failed to retrieve users", s));
                                             }

                                             await InvokeAsync(StateHasChanged);
                                         };
        return Task.CompletedTask;
    }

    private string GetPermissionsString(UserInfo user)
    {
        return user.Permissions.Length > 0 ? user.Permissions.Select(p => p.Name).Aggregate((a, b) => a + ", " + b) : "";
    }

    private async void AddPermissionToUser(int userID, string permission)
    {
        if (Auth.ApiKey is { } key)
        {
            int permissionID = Auth.PermissionsCache[permission];
            await UserManagement.AddPermissionToUser(Auth.ApiKey, userID, permissionID);
            var r = await UserManagement.GetUsers(key);
            UserManagement.UserInfos = r.GetValue(s => Dialogs.ShowError("Failed to retrieve users", s));
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void RemovePermissionFromUser(int userID, string permission)
    {
        if (Auth.ApiKey is { } key)
        {
            int permissionID = Auth.PermissionsCache[permission];
            await UserManagement.RemovePermissionFromUser(Auth.ApiKey, userID, permissionID);
            var r                      = await UserManagement.GetUsers(key);
            if (r.IsSuccess) UserManagement.UserInfos = r.GetValue(s => Dialogs.ShowError("Failed to retrieve users", s));
            await InvokeAsync(StateHasChanged);
        }
    }

    private string[] PermissionsNotAdded(Permission[] permissionsAdded)
    {
        var      perms         = Auth.PermissionsCache.Keys.ToList();
        string[] existingPerms = permissionsAdded.Select(p => p.Name).ToArray();
        return perms.Except(existingPerms).ToArray();
    }


    public bool HasPermissions
    {
        get
        {
            if (!Auth.PermissionsCache.TryGetValue("ManageUsers", out int _))
                return false;
            return UserProvider?.CurrentUser?.HasPermission(Auth.PermissionsCache["ManageUsers"]) ?? false;
        }
    }


    private async void DisableLoggingIn(int userID)
    {
        if (Auth.ApiKey is { } key)
        {
            await UserManagement.DisableLoggingIn(key, userID);

            UserManagement.UpdateState();
        }
    }

    private async void EnableLoggingIn(int userID)
    {
        if (Auth.ApiKey is { } key)
        {
            await UserManagement.EnableLoggingIn(key, userID);

            UserManagement.UpdateState();
        }
    }

    private async void DeleteUser(int userID)
    {
        if (Auth.ApiKey is { } key)
        {
            await UserManagement.DeleteUser(key, userID);

            UserManagement.UpdateState();
        }
    }


    private async Task UsernameChangeDialogConfirmButtonPressed()
    {
        if (_editingUserId is null)
            return;

        string newUserName = _editingUserName.Trim();
        if (string.Equals(newUserName, _editingOriginalUserName, StringComparison.Ordinal))
        {
            UsernameChangeDialogCancelButtonPressed();
            return;
        }

        if (Auth.ApiKey is { } key)
        {
            Result r = await UserManagement.RenameUser(key, _editingUserId.Value, newUserName);
            r.IfError(async void (errorMessage) => { await Dialogs.ShowError("Failed to change username", errorMessage); });
            if (r.IsSuccess)
            {
                UserInfo u   = UserManagement.UserInfos.FirstOrDefault(u => u.UserID == _editingUserId.Value);
                int      idx = UserManagement.UserInfos.IndexOf(u);
                u.UserName                    = newUserName;
                UserManagement.UserInfos[idx] = u;
            }
        }

        UsernameChangeDialogCancelButtonPressed();
        await InvokeAsync(StateHasChanged);
    }

    private void OpenUsernameChangeDialog(UserInfo user)
    {
        _editingUserId            = user.UserID;
        _editingUserName          = user.UserName;
        _editingOriginalUserName  = user.UserName;
        _isEditUsernameDialogOpen = true;
    }

    private void UsernameChangeDialogCancelButtonPressed()
    {
        _isEditUsernameDialogOpen = false;
        _editingUserId            = null;
        _editingUserName          = string.Empty;
        _editingOriginalUserName  = string.Empty;
    }


    protected override void OnInitialized()
    {
        _stateChangeHandler = () =>
                              {
                                  if (HasPermissions && Auth.ApiKey is { } key)
                                  {
                                      UserManagement.UpdateState();
                                  }
                                  else InvokeAsync(StateHasChanged);
                              };
        Auth.OnStateChanged += _stateChangeHandler;

        _ = UserManagement.StartAsync(Navigation.BaseUri, UserProvider!);
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            if (_stateChangeHandler != null)
                Auth.OnStateChanged -= _stateChangeHandler;
            return ValueTask.CompletedTask;
        }
        catch (Exception exception)
        {
            return ValueTask.FromException(exception);
        }
    }
}
