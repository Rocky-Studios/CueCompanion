@using BitzArt.Blazor.Cookies
@inject AuthService Auth
@inject ICookieService Cookies
@inject SimpleDialogService Dialogs
@rendermode InteractiveServer

<CascadingValue Value="this">
    @ChildContent
</CascadingValue>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    public Action? OnStateChanged { get; set; }

    public User? CurrentUser => Auth.User;
    
    protected override async Task OnInitializedAsync()
    {
        await Auth.StartAsync(Navigation.BaseUri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        Auth.IsLoading = true;

        string? key = await GetApiKey();

        if (key != null)
        {
            Result<(User user, string apiKey)> res = await Connect(key);
            res.GetValue(s => Dialogs.ShowError("Failed to connect with session key", s));
        }

        Auth.IsLoading = false;
        Auth.UpdateState();
        OnStateChanged?.Invoke();
    }

    public void Logout()
    {
        try
        {
            _ = RemoveApiKey();
            _ = Auth.ClearConnectionAsync();
        }
        catch (Exception exception)
        {
            Task.FromException(exception);
        }
    }

    public async Task<Result<(User user, string apiKey)>> Connect(string apiKey)
    {
        Result<(User user, string apiKey)> connectResult = await Auth.ConnectAsync(apiKey);
        if (connectResult.Value.apiKey is { } key)
        {
            await SetApiKey(key);
        }

        if (connectResult.Meta is { } meta && meta.TryGetValue("clearApiKey", out string? clear) && clear == "true")
        {
            await RemoveApiKey();
        }

        if (connectResult.Value.user is { } user)
        {
            Result<Permission[]> permissionsResult = await Auth.GetPermissionsForUserAsync();
            user.SetPermissions(permissionsResult.GetValue(s => Dialogs.ShowError("Failed to get permissions", s)));
        }

        return connectResult;
    }

    public async Task<Result<(User user, string apiKey)>> Connect(string username, string password)
    {
        Result<(User user, string apiKey)> result = await Auth.ConnectAsync(username, password);
        if (result.Value.apiKey is { } key)
        {
            await SetApiKey(key);
            Result<Permission[]> permissionsResult = await Auth.GetPermissionsForUserAsync();
            Auth.User?.SetPermissions(permissionsResult.GetValue(s => Dialogs.ShowError("Failed to get permissions", s)));
        }

        if (result.Meta is { } meta && meta.TryGetValue("clearApiKey", out string? clear) && clear == "true")
        {
            await RemoveApiKey();
        }

        return result;
    }

    public async Task<string?> GetApiKey()
    {
        Cookie? cookie = await Cookies.GetAsync("apiKey");
        return cookie?.Value;
    }

    public async Task SetApiKey(string key)
    {
        Auth.ApiKey = key;
        await Cookies.SetAsync("apiKey", key, DateTimeOffset.UtcNow.AddDays(1));
    }

    public async Task RemoveApiKey()
    {
        await Cookies.RemoveAsync("apiKey");
    }
}