@using BitzArt.Blazor.Cookies
@inject AuthService Auth
@inject ICookieService Cookies
@inject SimpleDialogService Dialogs
@rendermode InteractiveServer

<CascadingValue Value="this">
    @ChildContent
</CascadingValue>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    public Action? OnStateChanged { get; set; }

    public User? CurrentUser => Auth.User;
    
    protected override async Task OnInitializedAsync()
    {
        await Auth.StartAsync(Navigation.BaseUri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        Auth.isLoading = true;

        string? key = await GetSessionKey();

        if (key != null)
        {
            Result<(User user, string sessionKey)> res = await Connect(key);
            res.GetValue(s => Dialogs.ShowError("Failed to connect with session key", s));
        }

        Auth.isLoading = false;
        Auth.UpdateState();
        OnStateChanged?.Invoke();
    }

    public async Task Logout()
    {
        _ = RemoveSessionKey();
        _ = Auth.ClearConnectionAsync();
    }

    public async Task<Result<(User user, string sessionKey)>> Connect(string sessionKey)
    {
        Result<(User user, string sessionKey)> connectResult = await Auth.ConnectAsync(sessionKey);
        if (connectResult.Value.sessionKey is { } key)
        {
            await SetSessionKey(key);
        }

        if (connectResult.Value.user is { } user)
        {
            Result<Permission[]> permissionsResult = await Auth.GetPermissionsForUserAsync();
            user.SetPermissions(permissionsResult.GetValue(s => Dialogs.ShowError("Failed to get permissions", s)));
        }

        return connectResult;
    }

    public async Task<Result<(User user, string sessionKey)>> Connect(string username, string password)
    {
        Result<(User user, string sessionKey)> result = await Auth.ConnectAsync(username, password);
        if (result.Value.sessionKey is { } key)
        {
            await SetSessionKey(key);
            Result<Permission[]> permissionsResult = await Auth.GetPermissionsForUserAsync();
            Auth.User?.SetPermissions(permissionsResult.GetValue(s => Dialogs.ShowError("Failed to get permissions", s)));
        }

        return result;
    }

    public async Task<string?> GetSessionKey()
    {
        Cookie? cookie = await Cookies.GetAsync("sessionKey");
        return cookie?.Value;
    }

    public async Task SetSessionKey(string key)
    {
        Auth.SessionKey = key;
        await Cookies.SetAsync("sessionKey", key, DateTimeOffset.UtcNow.AddDays(1));
    }

    public async Task RemoveSessionKey()
    {
        await Cookies.RemoveAsync("sessionKey");
    }
}