@inject AuthService         Auth
@inject NotesService        NotesService
@inject SimpleDialogService Dialogs
@using CueCompanion.Notes
@implements IDisposable

<GridChild ColumnStart="3" ColumnEnd="4" RowStart="1" RowEnd="2">
    <MudText Typo="Typo.h1">Notes
        <MudButton OnClick="() => { 
            _isNewNoteFormExpanded = !_isNewNoteFormExpanded;
        }">@(_isNewNoteFormExpanded ? "Close note creation..." : "Show note creation...")</MudButton>
    </MudText>
    @if (ShowService.CurrentlyViewingShow is not { } show)
    {
        <MudAlert Severity="Severity.Warning">No show loaded. Load a show to view and create notes.</MudAlert>
    }
    else
    {
        @if (NotesService.GetCurrentlyVisibleNotes() is
             {
                 Length: > 0,
             } notes)
        {
            <div class="d-flex flex-column gap-2">
                @foreach (Note note in notes)
                {
                    <NoteCard NotesService="NotesService" ThisNote="note"/>
                }
            </div>
        }
        else
        {
            <MudText>No notes found for this show.</MudText>
        }

        <MudCollapse Expanded="_isNewNoteFormExpanded">
            <div style="height: 16px;"></div>
            <MudCard>
                <MudForm>
                    <MudStack Spacing="2">
                        <MudTextField Label="Note Text" @bind-Value="_newNoteText" Clearable="true"/>
                        <br/>
                        <MudSelect T="NoteAssignment" Label="Assigned to" @bind-Value="_assignment" Dense="true">
                            <MudSelectItem Value="NoteAssignment.SingleCue">Single cue</MudSelectItem>
                            <MudSelectItem Value="NoteAssignment.CueList">Multiple cues</MudSelectItem>
                            <MudSelectItem Value="NoteAssignment.AllCues">All cues</MudSelectItem>
                            <MudSelectItem Value="NoteAssignment.AllShows">All shows</MudSelectItem>
                        </MudSelect>
                        <div>
                            @if (_assignment == NoteAssignment.SingleCue)
                            {
                                <MudSelect T="int?" Label="Cue" @bind-Value="singleCueAssignment"
                                           Placeholder="Select a cue..." Dense="true">
                                    @foreach (Cue cue in ShowService.Cues)
                                    {
                                        <MudSelectItem T="int?" Value="@cue.Position">@cue.Name (@cue.Position)
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            }
                            else if (_assignment == NoteAssignment.CueList)
                            {
                                <MudTooltip>
                                    <ChildContent>
                                        <MudTextField Label="Cue Positions"
                                                      @bind-Value="cueListAssignmentString"></MudTextField>
                                    </ChildContent>
                                    <TooltipContent>
                                        <div style="max-width: 300px; text-align: left;">
                                            <p>Enter cue positions to assign the note to. Supported formats:</p>
                                            <ul>
                                                <li><strong>Single cue:</strong> 3</li>
                                                <li><strong>Range of cues:</strong> 1-5</li>
                                                <li><strong>Multiple specific cues:</strong> 1,3,5</li>
                                                <li><strong>Combination of formats:</strong> 1,3,5-7</li>
                                            </ul>
                                        </div>
                                    </TooltipContent>
                                </MudTooltip>
                            }
                        </div>

                        <MudSelect T="NoteVisibility" Label="Visible to" @bind-Value="_visibility" Dense="true">
                            <MudSelectItem Value="NoteVisibility.Me">Me</MudSelectItem>
                            <MudSelectItem Value="NoteVisibility.EveryoneWithRole">Everyone with my role</MudSelectItem>
                            <MudSelectItem Value="NoteVisibility.Everyone">Everyone</MudSelectItem>
                        </MudSelect>

                        <MudButton OnClick="@(() => CreateNote(_newNoteText, null))"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary">
                            Add Note
                        </MudButton>
                    </MudStack>
                </MudForm>
            </MudCard>
        </MudCollapse>
    }
</GridChild>

@code
{
    [CascadingParameter]
    public required ShowService ShowService { get; set; }

    private string _newNoteText       = "";
    private bool   _isNewNoteFormExpanded;
    private int?   singleCueAssignment;
    private string cueListAssignmentString = "";
    private Action? _authStateChangedHandler;

    private int[] GetCueListAssignment()
    {
        if (_assignment is NoteAssignment.SingleCue)
        {
            return [singleCueAssignment!.Value];
        }

        // The client will display regardless of the cue assignment, so no need to assign 
        if (_assignment is NoteAssignment.AllCues or NoteAssignment.AllShows) return [];
        string    cleanText = cueListAssignmentString.Trim().Replace(" ", "");
        List<int> cueIds    = new();
        foreach (string fragment in cleanText.Split(',', StringSplitOptions.RemoveEmptyEntries))
        {
            if (fragment.Contains('-'))
            {
                // Range
                string[] rangeParts = fragment.Split('-', StringSplitOptions.RemoveEmptyEntries);
                if (rangeParts.Length == 2                     &&
                    int.TryParse(rangeParts[0], out int start) &&
                    int.TryParse(rangeParts[1], out int end))
                {
                    cueIds.AddRange(Enumerable.Range(start, end - start + 1));
                }
            }
            else if (int.TryParse(fragment, out int cueId))
            {
                //Single cue
                cueIds.Add(cueId);
            }
            else throw new InvalidOperationException($"Invalid cue assignment format: '{fragment}'");
        }

        return cueIds.ToArray();
    }

    private NoteVisibility _visibility = NoteVisibility.Me;
    private NoteAssignment _assignment = NoteAssignment.SingleCue;

    protected override async Task OnInitializedAsync()
    {
        _authStateChangedHandler =  () => _ = LoadNotesAsync();
        Auth.OnStateChanged      += _authStateChangedHandler;
        NotesService.OnStateChanged += NotesOnStateChanged;

        await NotesService.StartAsync(Navigation.BaseUri);
        await LoadNotesAsync();
    }

    private void NotesOnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadNotesAsync()
    {
        if (Auth.SessionKey is null)
            return;

        Result<Note[]> notesResult = await NotesService.GetAllNotes();
        notesResult.GetValue(s => Dialogs.ShowError("Failed to load notes", s));

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_authStateChangedHandler is not null)
            Auth.OnStateChanged -= _authStateChangedHandler;
        NotesService.OnStateChanged -= NotesOnStateChanged;
    }

    private async Task CreateNote(string noteText, int? roleID)
    {
        if (noteText.Length == 0)
        {
            _ = Dialogs.ShowError("Failed to create note", "Note text cannot be empty.");
            return;
        }

        if (singleCueAssignment is null)
        {
            _ = Dialogs.ShowError("Failed to create note", "Please select a cue for the note.");
            return;
        }
        int[]  cues     = GetCueListAssignment();

        if (cues.Length == 0 && _assignment is not (NoteAssignment.AllCues or NoteAssignment.AllShows))
        {
            _ = Dialogs.ShowError("Failed to create note", "Please select cues for the note.");
            return;
        }
        byte[] noteCues = new byte[cues.Length * sizeof(int)];
        for (int i = 0; i < cues.Length; i++)
        {
            BitConverter.GetBytes(cues[i]).CopyTo(noteCues, i * sizeof(int));
        }

        Note note = new()
        {
            NoteText       = noteText,
            RoleId         = roleID,
            Visibility     = _visibility,
            Assignment     = _assignment,
            CueListAsBytes = noteCues,
        };
        if (_assignment is not NoteAssignment.AllShows)
        {
            note.ShowId = ShowService.CurrentlyViewingShow?.Id;
        }
        Result noteResult = await NotesService.CreateNote(note);
        noteResult.IfError(e => Dialogs.ShowError("Failed to create note", e));
        _ = InvokeAsync(StateHasChanged);
    }
}
