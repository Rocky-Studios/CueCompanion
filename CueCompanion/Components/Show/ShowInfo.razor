@inject AuthService         Auth
@inject SimpleDialogService Dialogs
@using System.Globalization
@using System.Text.Json
@implements IAsyncDisposable
@inject IJSRuntime          JsRuntime
@inject ISnackbar           Snackbar
@inject IDialogService      DialogService


<MudPaper>
    <MudText Typo="Typo.h1" Align="Align.Center">Show Info</MudText>
    <div style="display:flex; align-items:center; gap:8px;">
        @if (HasControlPermissions)
        {
            string text = ShowService.IsEditMode ? "Live mode cannot be changed while in edit mode." : IsLiveMode ? "Stop live mode" : "Start live mode";
            <MudTooltip Text="@text">
                @if (IsLiveMode)
                {
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="@OnStopShow"
                               Disabled="@IsShowStartStopButtonsDisabled">Stop
                    </MudButton>
                }
                else
                {
                    <MudButton Color="Color.Primary" Variant="Variant.Outlined" OnClick="@OnStartShow"
                               Disabled="@IsShowStartStopButtonsDisabled">Start
                    </MudButton>
                }
            </MudTooltip>
        }
        <MudSelect T="Show?" Style="flex:1;" ToStringFunc="ShowToStringFunc" @bind-Value="@SelectedShowBound">
            @{
                var shows = ShowService!.Shows.ToList();
                shows.Sort((a, b) =>
                           {
                               bool aIsToday = IsShowToday(a, false);
                               bool bIsToday = IsShowToday(b, false);
                               if (aIsToday != bIsToday) return aIsToday ? -1 : 1;
                               return DateTime.Compare(a.Start, b.Start);
                           });
            }
            @if (shows.Count == 0 || SelectedShowBound == null)
            {
                <MudSelectItem Value="@null" T="Show?"/>
            }
            @foreach (Show showSelectOption in shows)
            {
                <MudSelectItem @key="showSelectOption.Id" Value="@showSelectOption">
                    @ShowToStringFunc(showSelectOption)
                    @if (IsShowToday(showSelectOption, true))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled"
                                 Style="margin-left:4px;">Today
                        </MudChip>
                        <MudDivider Light="false"/>
                    }
                </MudSelectItem>
            }
        </MudSelect>
        @if (HasEditPermissions)
        {
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <ShowActionButtons NewShowButtonPressed="NewShowButtonPressed"
                                   DeleteShowButtonPressed="DeleteShowButtonPressed"
                                   DuplicateShowButtonPressed="DuplicateShowButtonPressed"
                                   OnFileUploadPressed="OnFileUploadPressed"
                                   OnImportFileSelected="OnImportFileSelected"
                                   IsEditMode="ShowService.IsEditMode"/>
            </MudHidden>
        }
    </div>
    @if (ShowService!.CurrentlyViewingShow is { } show)
    {
        <MudStack Row="true" Justify="Justify.SpaceBetween">
            <div>
                <EditableText Label="Show Name:" @bind-Value="show.Name" IsEditMode="ShowService.IsEditMode"
                              OnValueChanged="ShowNameChanged"/>
                <MudText Typo="Typo.subtitle2">Show ID: @show.Id</MudText>
            </div>
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <div>
                    <MudTooltip Text="Export as JSON">
                        <MudButton Color="Color.Primary" EndIcon="@Icons.Material.Filled.FileDownload"
                                   Disabled="@(ShowService.CurrentlyViewingShow is null)" OnClick="@OnExportShow">
                            Export
                        </MudButton>
                    </MudTooltip>
                    <MudTooltip Text="Export as PDF">
                        <MudButton Color="Color.Primary" EndIcon="@Icons.Material.Filled.PictureAsPdf"
                                   Disabled="@(ShowService.CurrentlyViewingShow is null)" OnClick="@OnExportPDF">
                            Export
                        </MudButton>
                    </MudTooltip>
                </div>
            </MudHidden>
        </MudStack>

        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="0">
                <MudTooltip Text="Export as JSON">
                    <MudButton Color="Color.Primary" EndIcon="@Icons.Material.Filled.FileDownload"
                               Disabled="@(ShowService.CurrentlyViewingShow is null)" OnClick="@OnExportShow">
                        Export
                    </MudButton>
                </MudTooltip>
                <MudTooltip Text="Export as PDF">
                    <MudButton Color="Color.Primary" EndIcon="@Icons.Material.Filled.PictureAsPdf"
                               Disabled="@(ShowService.CurrentlyViewingShow is null)" OnClick="@OnExportPDF">
                        Export
                    </MudButton>
                </MudTooltip>
                <ShowActionButtons NewShowButtonPressed="NewShowButtonPressed"
                                   DeleteShowButtonPressed="DeleteShowButtonPressed"
                                   DuplicateShowButtonPressed="DuplicateShowButtonPressed"
                                   OnFileUploadPressed="OnFileUploadPressed"
                                   OnImportFileSelected="OnImportFileSelected"/>
            </MudStack>
        </MudHidden>

        <MudDivider/>
        <table class="show-info-table">
            @if (!ShowService.IsEditMode)
            {
                <tr>
                    <td>Date</td>
                    <td>@show.Start.ToLongDateString()</td>
                </tr>
                <tr>
                    <td>Start</td>
                    <td>@show.Start.ToShortTimeString()</td>
                </tr>
                <tr>
                    <td>End</td>
                    <td>@show.End.ToShortTimeString()</td>
                </tr>
            }
            else
            {
                <tr>
                    <td>Date</td>
                    <td>
                        <MudDatePicker Date="@_selectedDate" DateChanged="OnDateChanged" Culture="@CultureInfo.GetCultureInfo("en-gb")"/>
                    </td>
                </tr>
                <tr>
                    <td>Start</td>
                    <td>
                        <MudTimePicker Time="@_selectedStart" TimeChanged="OnStartTimeChanged"/>
                    </td>
                </tr>
                <tr>
                    <td>End</td>
                    <td>
                        <MudTimePicker Time="@_selectedEnd" TimeChanged="OnEndTimeChanged"/>
                    </td>
                </tr>
            }
            <tr>
                <td>Live</td>
                <td>@(ShowService.IsLiveMode)</td>
            </tr>
            <tr>
                <td>Number of Cues</td>
                <td>@ShowService.GetCuesInShow().Count()</td>
            </tr>
        </table>
    }
</MudPaper>
<InputFile id="@IMPORT_INPUT_ID" style="display:none;" accept=".json,application/json"
           OnChange="@OnImportFileSelected"/>
<style>
    .show-info-table {
        width: 100%;
    }

    .show-info-table td:first-child {
        font-weight: 700;
    }

    .show-info-table td:last-child {
        text-align: right;
    }
</style>

@code
{
    private const string IMPORT_INPUT_ID = "show-info-import-input";

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true,
    };

    private bool IsLiveMode => ShowService?.LiveModeCuePosition != null;
    public bool HasControlPermissions
    {
        get
        {
            if (!Auth.PermissionsCache.TryGetValue("ControlShow", out int _)) return false;
            return UserProvider.CurrentUser?.HasPermission(Auth.PermissionsCache["ControlShow"]) ?? false;
        }
    }

    public bool HasEditPermissions
    {
        get
        {
            if (!Auth.PermissionsCache.TryGetValue("EditShow", out int _)) return false;
            return UserProvider.CurrentUser?.HasPermission(Auth.PermissionsCache["EditShow"]) ?? false;
        }
    }
    [CascadingParameter]
    public ShowService? ShowService { get; set; }

    private bool IsShowStartStopButtonsDisabled => ShowService.IsEditMode || SelectedShowBound == null;


    [CascadingParameter]
    public required UserProvider UserProvider { get; set; }

    public Show? SelectedShowBound
    {
        get => ShowService!.CurrentlyViewingShow;
        set
        {
            ShowService!.CurrentlyViewingShow = value;
            _                                 = SelectedShowChanged(value);
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            ShowService?.OnStateChanged += ShowInfoChanged;
        }

        return Task.CompletedTask;
    }

    private DateTime? _selectedDate;
    private TimeSpan? _selectedStart;
    private TimeSpan? _selectedEnd;
    private bool      _updateLock;

    private void ShowInfoChanged()
    {
        Show? show = ShowService!.CurrentlyViewingShow;
        _updateLock                      = true;
        ShowService.CurrentlyViewingShow = show;
        _selectedDate                    = show?.Start.Date;
        _selectedStart                   = show?.Start.TimeOfDay;
        _selectedEnd                     = show?.End.TimeOfDay;
        _updateLock                      = false;
        if (ShowService.IsLiveMode && SelectedShowBound == null && ShowService.LiveModeShow is { } liveModeShow)
            // Automatically select live show if none is selected
            SelectedShowBound = liveModeShow;
    }

    private async Task OnDateChanged(DateTime? newDate)
    {
        if (_updateLock) return;
        _selectedDate = newDate;
        await ShowDateOrTimeChanged();
    }

    private async Task OnStartTimeChanged(TimeSpan? newTime)
    {
        if (_updateLock) return;
        _selectedStart = newTime;
        await ShowDateOrTimeChanged();
    }

    private async Task OnEndTimeChanged(TimeSpan? newTime)
    {
        if (_updateLock) return;
        _selectedEnd = newTime;
        await ShowDateOrTimeChanged();
    }

    private async Task ShowDateOrTimeChanged()
    {
        if (_updateLock) return;
        if (ShowService!.CurrentlyViewingShow is { } show && Auth.ApiKey is { } key)
        {
            _updateLock = true;
            DateTime newStart = _selectedDate?.Add(_selectedStart ?? TimeSpan.Zero) ?? show.Start;
            DateTime newEnd = _selectedDate?.Add(_selectedEnd ?? TimeSpan.Zero) ?? show.End;
            show.Start = newStart;
            show.End = newEnd;
            await ShowService.SendEditModeAction(key, EditModeMethod.Update, show);
            _updateLock = false;
        }
    }

    private async Task ShowNameChanged(string newName)
    {
        if (newName.Length == 0)
        {
            _ = Dialogs.Show("Invalid show name", "Show name cannot be empty.");
            return;
        }
        if (ShowService!.CurrentlyViewingShow is { } show && Auth.ApiKey is { } key)
        {
            show.Name = newName;
            await ShowService.SendEditModeAction(key, EditModeMethod.Update, show);
        }
    }

    ValueTask IAsyncDisposable.DisposeAsync()
    {
        ShowService!.OnStateChanged -= ShowInfoChanged;

        return ValueTask.CompletedTask;
    }

    private async Task NewShowButtonPressed()
    {
        Show newShow = new()
        {
            Name  = "New Show",
            Start = DateTime.Now,
            End   = DateTime.Now.AddHours(1),
        };
        if (Auth.ApiKey is { } key)
        {
            var r = await ShowService!.SendEditModeAction(key, EditModeMethod.Create, newShow);
            r.IfError(e => Dialogs.Show("Failed to create new show", e));
            if (r.Value is not { } returnedShow) return;
            if (ShowService.Shows.Any(s => s.Id == returnedShow.Id))
            {
                SelectedShowBound = returnedShow;
                return; // Show already exists in list, no need to add
            }
            ShowService.Shows = ShowService.Shows.Append(returnedShow).ToArray();
            SelectedShowBound = returnedShow;
        }
    }

    private async void DeleteShowButtonPressed(int showId)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
                           "Warning",
                           "Deleting show can not be undone!",
                           "Delete!", cancelText: "Cancel");

        if ((result == null ? "Canceled" : "Deleted!") != "Deleted!") return;

        if (Auth.ApiKey is { } key)
        {
            Show show = ShowService!.Shows.FirstOrDefault(s => s.Id == showId) ?? new Show { Id = showId };
            if (ShowService.LiveModeShowID == showId)
            {
                _ = Dialogs.Show("Cannot delete show", "You cannot delete a show that is currently live.");
                return;
            }

            var r = await ShowService.SendEditModeAction(key, EditModeMethod.Delete, show);
            r.IfError(e => Dialogs.Show("Failed to delete show", e));
            ShowService.Shows                = ShowService.Shows.ToList().Where(s => s.Id != showId).ToArray();
            Show? nextSelectShow = null;
            if (ShowService.Shows.Length > 0)
                nextSelectShow = ShowService.Shows[0];
            ShowService.CurrentlyViewingShow = nextSelectShow;
            ShowService.UpdateState();
        }
    }

    private async void DuplicateShowButtonPressed(int showId)
    {
        if (ShowService!.CurrentlyViewingShow is not { } show)
        {
            _ = Dialogs.Show("Failed to duplicate show", "Please select a show to duplicate.");
            return;
        }

        if (Auth.ApiKey is not { } key)
        {
            _ = Dialogs.Show("Failed to duplicate show", "No active session key was found.");
            return;
        }

        var bundleResult = await ShowService.GetShowBundle(key, show.Id);
        if (!bundleResult.IsSuccess)
        {
            _ = Dialogs.Show("Failed to duplicate show", bundleResult.Error ?? "Unable to load the show bundle.");
            return;
        }

        ShowBundle bundle = bundleResult.Value;
        bundle.Show.Name += " (Copy)";
        Result importResult = await ShowService!.AddShowFromBundle(key, bundle);
        importResult.IfError(e => Dialogs.Show("Failed to duplicate show", e));
        if (importResult.IsSuccess)
        {
            Snackbar.Add($"Show {show.Name} duplicated successfully.", Severity.Success);
        }

        (await ShowService.GetShowsAndRoles(key)).IfError(e => Dialogs.Show("Show duplicated, but failed to refresh list",      e));
        (await ShowService.GetLiveInfoAsync(key)).IfError(e => Dialogs.Show("Show duplicated, but failed to refresh live info", e));
    }

    private static string ShowToStringFunc(Show? show)
    {
        if (show is null) return "No show";
        return show.Name + " (" + show.Start.ToShortDateString() + ")";
    }

    private bool IsShowToday(Show show, bool falseIfSelected)
    {
        if (falseIfSelected && show.Id == ShowService!.CurrentlyViewingShow?.Id) return false;
        DateTime today = DateTime.Today;
        return show.Start.Date == today || show.End.Date == today;
    }

    private async Task SelectedShowChanged(Show? newShow)
    {
        ShowService!.CurrentlyViewingShow = newShow;
        if (Auth.ApiKey is { } key)
        {
            (await ShowService.GetShowsAndRoles(key)).IfError(e => Dialogs.Show("Error loading show", e));
            (await ShowService.GetLiveInfoAsync(key)).IfError(e => Dialogs.Show("Error loading show", e));
        }

        ShowService.UpdateState();
    }

    private async Task OnStartShow()
    {
        if (HasControlPermissions && Auth.ApiKey is { } key)
        {
            if (ShowService!.CurrentlyViewingShow == null)
            {
                _ = Dialogs.Show("Error starting show", "Please select a show to start.");
                return;
            }

            Result r = await ShowService.SelectShowAsync(key, ShowService.CurrentlyViewingShow.Id);
            r.IfError(e => Dialogs.Show("Error starting show", e));
            if (r.IsSuccess) Snackbar.Add($"Show {ShowService.CurrentlyViewingShow!.Name} is now live.", Severity.Success);
            (await ShowService.StartShowAsync(key)).IfError(e => Dialogs.Show("Error starting show", e));
        }
    }

    private async Task OnStopShow()
    {
        if (HasControlPermissions && Auth.ApiKey is { } key)
        {
            if (ShowService!.CurrentlyViewingShow == null)
            {
                _ = Dialogs.Show("Error stopping show", "Please select a show to stop.");
                return;
            }

            Result r = await ShowService.StopShowAsync(key);
            r.IfError(e => Dialogs.Show("Error stopping show", e));
            if (r.IsSuccess) Snackbar.Add($"Show {ShowService.CurrentlyViewingShow!.Name} has been stopped.", Severity.Success);
            (await ShowService.SelectShowAsync(key, null)).IfError(e => Dialogs.Show("Error stopping show", e));
        }
    }

    private async Task OnFileUploadPressed()
    {
        await JsRuntime.InvokeVoidAsync("cueCompanionShowInfo.openImportPicker", IMPORT_INPUT_ID);
    }

    private async Task OnExportShow()
    {
        if (ShowService!.CurrentlyViewingShow is not { } show)
        {
            _ = Dialogs.Show("Failed to export show", "Please select a show to export.");
            return;
        }

        if (Auth.ApiKey is not { } key)
        {
            _ = Dialogs.Show("Failed to export show", "No active session key was found.");
            return;
        }

        var bundleResult = await ShowService.GetShowBundle(key, show.Id);
        if (!bundleResult.IsSuccess)
        {
            _ = Dialogs.Show("Failed to export show", bundleResult.Error ?? "Unable to load the show bundle.");
            return;
        }

        ShowBundle bundle = bundleResult.Value;

        string json = JsonSerializer.Serialize(bundle, new JsonSerializerOptions
        {
            WriteIndented = true,
        });

        string fileName = BuildExportFileName(show, "json");
        await JsRuntime.InvokeVoidAsync("cueCompanionShowInfo.downloadFile", fileName, "application/json;charset=utf-8", json);
        Snackbar.Add($"Show {show.Name} exported successfully.", Severity.Success);
    }
    
    private async Task OnExportPDF()
    {
        if (ShowService!.CurrentlyViewingShow is not { } show)
        {
            _ = Dialogs.Show("Failed to export show", "Please select a show to export.");
            return;
        }

        if (Auth.ApiKey is not { } key)
        {
            _ = Dialogs.Show("Failed to export show", "No active session key was found.");
            return;
        }

        // Show dialog to get export options
        IDialogReference dialog = await DialogService.ShowAsync<PDFExportDialog>("PDF Export Options");
        DialogResult?    result = await dialog.Result;

        if (result.Canceled)
            return;

        PDFExportOptions? options = (PDFExportOptions)result.Data;

        var bundleResult = await ShowService.GetShowBundle(key, show.Id);
        if (!bundleResult.IsSuccess)
        {
            _ = Dialogs.Show("Failed to export show", bundleResult.Error ?? "Unable to load the show bundle.");
            return;
        }

        ShowBundle bundle = bundleResult.Value;

        byte[] pdfBytes  = PDFExport.GeneratePDF(bundle, options);
        string pdfString = Convert.ToBase64String(pdfBytes);

        string fileName = BuildExportFileName(show, "pdf");
        await JsRuntime.InvokeVoidAsync("cueCompanionShowInfo.downloadFile", fileName, "application/pdf;charset=utf-8", pdfBytes);
        Snackbar.Add($"Show {show.Name} exported successfully.", Severity.Success);
    }

    private static string BuildExportFileName(Show show, string extension)
    {
        string baseName     = string.IsNullOrWhiteSpace(show.Name) ? $"show-{show.Id}" : show.Name;
        char[] invalidChars = Path.GetInvalidFileNameChars();
        char[] chars        = baseName.Select(c => invalidChars.Contains(c) ? '_' : c).ToArray();
        return $"{new string(chars)}."+extension;
    }

    private async Task OnImportFileSelected(InputFileChangeEventArgs args)
    {
        if (Auth.ApiKey is not { } key)
        {
            _ = Dialogs.Show("Failed to import show", "No active session key was found.");
            return;
        }

        try
        {
            await using Stream stream = args.File.OpenReadStream(50 * 1024 * 1024);
            ShowBundle?        bundle;
            try
            {
                bundle = await JsonSerializer.DeserializeAsync<ShowBundle>(stream, JsonOptions);
            }
            catch (Exception e)
            {
                _ = Dialogs.Show("Failed to import show", $"The selected file is not a valid show. \n\n {e.Message}");
                return;
            }

            ShowBundle importedBundle = bundle.Value;
            string     name           = importedBundle.Show.Name;
            importedBundle.Show.Name += " (Imported)";

            Result importResult = await ShowService!.AddShowFromBundle(key, importedBundle);
            if (!importResult.IsSuccess)
            {
                _ = Dialogs.Show("Failed to import show", importResult.Error ?? "Unknown error");
                return;
            }
            else
            {
                Snackbar.Add($"Show {name} imported successfully.", Severity.Success);
            }

            (await ShowService.GetShowsAndRoles(key)).IfError(e => Dialogs.Show("Show imported, but failed to refresh list",      e));
            (await ShowService.GetLiveInfoAsync(key)).IfError(e => Dialogs.Show("Show imported, but failed to refresh live info", e));
        }
        catch (Exception e)
        {
            _ = Dialogs.Show("Failed to import show", e.Message);
        }
    }
}
