@inject AuthService Auth
@inject SimpleDialogService Dialogs

<GridChild ColumnStart="1" ColumnEnd="2" RowStart="1" RowEnd="3">
    <MudText Typo="Typo.h1" Inline="true">
        Cue Explorer
    </MudText>
    @if (ShowService.LiveModeCuePosition is { } cuePos && !IsEditMode)
    {
        <MudText Typo="Typo.h2" Inline="true">
            <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="@PreviousCue" Color="Color.Primary"/>
            @cuePos
            <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="@NextCue" Color="Color.Primary"/>
            <MudTooltip Text="Automatically jump if the next cue goes live" Inline="true">
                @{
                    string icon = _followLiveCue ? Icons.Material.Filled.Link : Icons.Material.Filled.LinkOff;
                    Color  c    = _followLiveCue ? Color.Primary : Color.Default;
                }
                <MudIconButton Icon="@icon" OnClick="@(() => { _followLiveCue = !_followLiveCue; })" Color="@c"/>
            </MudTooltip>
        </MudText>
    }
    @if (ShowService.CurrentlyViewingShow is { } show)
    {

            <MudCard Elevation="4" style="background-color: #141414">
                <div class="d-flex justify-content-between">
                    <MudText Typo="Typo.subtitle1">CUES</MudText>
                    @if (IsEditMode)
                    {
                        <MudTooltip Text="Add new cue">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                           OnClick="@CreateNewCue"
                                           Size="Size.Small"/>
                        </MudTooltip>
                        <MudTooltip Text="Delete all cues">
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Primary"
                                           OnClick="@DeleteAllCuesButtonPressed"
                                           Size="Size.Small"/>
                        </MudTooltip>
                    }
                    <MudText Typo="Typo.subtitle1">@ShowService.GetCuesInShow().Count() ITEMS</MudText>
                </div>
                <div Class="d-flex flex-column gap-1">
                    @foreach (Cue cue in GetSortedCues())
                    {
                        <CueCard @key="cue.Position" Cue="@cue"
                                 IsSelected="@(ShowService.CurrentCuePosition == cue.Position)"
                                 IsSelectedLive="@(ShowService.LiveModeCuePosition == cue.Position)"
                                 OnClick="@(() => OnCueCardClick(cue))"/>
                    }
                </div>
            </MudCard>
    }
    else
    {
        <MudText>No show loaded</MudText>
    }
    
</GridChild>


@code
{
    [CascadingParameter]
    public required ShowService ShowService { get; set; }

    [CascadingParameter]
    public required UserProvider UserProvider { get; set; }

    [CascadingParameter(Name = "IsEditMode")]
    public bool IsEditMode { get; set; }
    public bool HasControlPermissions
    {
        get
        {
            if (!Auth.PermissionsCache.TryGetValue("ControlShow", out int _)) return false;
            return UserProvider.CurrentUser?.HasPermission(Auth.PermissionsCache["ControlShow"]) ?? false;
        }
    }

    private int? _loadedShowId;
    private bool _isLoadingCues;
    private bool _followLiveCue = true;

    protected override async Task OnParametersSetAsync()
    {
        if (_isLoadingCues) return;
        if (Auth.ApiKey is not { } key) return;
        if (ShowService.CurrentlyViewingShow?.Id is not { } showId) return;
        if (_loadedShowId == showId) return;

        _isLoadingCues = true;
        try
        {
            (await ShowService.GetCuesForShowAsync(key, showId)).IfError(e => Dialogs.ShowError("Error loading cues", e));
            _loadedShowId = showId;
        }
        finally
        {
            _isLoadingCues = false;
        }

        ShowService.OnLiveCueChanged += () =>
                                        {
                                            if (!ShowService.IsLiveMode) return;
                                            if (_followLiveCue) ShowService.CurrentCuePosition = ShowService.LiveModeCuePosition;
                                            ShowService.UpdateState();
                                        };
    }

    private void OnCueCardClick(Cue cue)
    {
        ShowService.CurrentCuePosition = cue.Position;
        ShowService.UpdateState();

        StateHasChanged();
    }


    public async Task PreviousCue()
    {
        if (HasControlPermissions && Auth.ApiKey is { } key)
        {
            (await ShowService.PreviousCueAsync(key)).IfError(e => Dialogs.ShowError("Error moving to previous cue", e));
        }
    }

    public async Task NextCue()
    {
        if (HasControlPermissions && Auth.ApiKey is { } key)
        {
            (await ShowService.NextCueAsync(key)).IfError(e => Dialogs.ShowError("Error moving to next cue", e));
        }
    }

    private async Task CreateNewCue()
    {
        if (ShowService.CurrentlyViewingShow is { Id: { } showID } && HasControlPermissions && Auth.ApiKey is { } key)
        {
            var cues            = ShowService.GetCuesInShow().ToArray();
            int lastCuePosition = cues.Length > 0 ? cues.Max(c => c.Position) : 0;
            Cue newCue = new()
            {
                Name = "New Cue",
                ShowId = showID,
                Position = lastCuePosition + 1,
            };
            (await ShowService.SendEditModeAction(key, EditModeMethod.Create, newCue)).IfError(e => Dialogs.ShowError("Error creating new cue", e));
        }
    }

    private async Task DeleteAllCuesButtonPressed()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
                           "Warning",
                           "Deleting all cues can not be undone!",
                           "Delete!", cancelText: "Cancel");

        if ((result == null ? "Canceled" : "Deleted!") != "Deleted!") return;


        if (ShowService.CurrentlyViewingShow is { Id: { } showID } && Auth.ApiKey is { } key)
        {
            // Need to pass a cue to tell it in which show
            Cue firstCue = ShowService.GetCuesInShow().First();
            (await ShowService.SendEditModeAction(key, EditModeMethod.DeleteAll, firstCue)).IfError(e => Dialogs.ShowError("Error deleting cues", e));
        }
    }
    
    private IEnumerable<Cue> GetSortedCues()
    {
        return ShowService.GetCuesInShow().OrderBy(c => c.Position);
    }
}
