@inject AuthService         Auth
@inject SimpleDialogService Dialogs
@using System.ComponentModel.DataAnnotations
@implements IDisposable
<GridChild ColumnStart="2" ColumnEnd="2" RowStart="1" RowEnd="3">
    @if (ShowService is
        {
            TasksForCurrentCue: { } tasks,
            Roles             : { } roles,
        })
    {
        _currentCue   = ShowService.CurrentCue;
        _currentTasks = IsEditMode ? ShowService.Tasks.Where(t => t.CueId == _currentCue?.Id).ToList() : tasks.ToList();

        if (_currentCue is not null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.h1">Current Cue - @_currentCue.Name </MudText>
                <MudTooltip Text="Delete all tasks">
                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Primary"
                                   OnClick="@DeleteAllTasksButtonPressed"
                                   Size="Size.Medium"/>
                </MudTooltip>
            </MudStack>

            @if (!IsEditMode)
            {
                <div class="d-flex flex-grow-1 flex-wrap justify-center align-center px-8 pb-8 pt-2">
                    <MudCheckBox Color="Color.Primary" Label="All" Dense="true" T="bool?"
                                 Value="@AllRolesSelected" ValueChanged="OnAllRolesChanged"></MudCheckBox>
                    @foreach (Role role in roles)
                    {
                        <MudCheckBox Color="Color.Primary" Label="@role.Name" T="bool" Dense="true"
                                     @bind-Value="_roleFilters[role.Id]"/>
                    }
                </div>
            }

            <div>
                @foreach (CueTask cueTask in _currentTasks)
                {
                    @if (cueTask.RoleId is null)
                    {
                        <MudText Typo="Typo.h3">Unassigned</MudText>
                        <EditableText Value="@cueTask.Tasks" IsEditMode="@IsEditMode" OnValueChanged="s => {
                                          CueTaskChanged(s,cueTask);
                                      }"/>
                    }
                    else if (_roleFilters[cueTask.RoleId.Value] || IsEditMode)
                    {
                        Role? role = roles.FirstOrDefault(r => r.Id == cueTask.RoleId.Value);
                        if (role is not null)
                        {
                            <MudText Typo="Typo.h3">@role.Name
                                @if (IsEditMode)
                                {
                                    <MudTooltip Text="Delete task">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   OnClick="@(() => { DeleteCueTask(cueTask); })"
                                                   Color="Color.Primary"/>
                                    </MudTooltip>
                                }
                            </MudText>
                            <EditableText Value="@cueTask.Tasks" Label="" IsEditMode="@IsEditMode" OnValueChanged="s => {
                            CueTaskChanged(s,cueTask);
                                          }" MaxLines="20"></EditableText>
                            <MudDivider/>
                        }
                    }
                }
                <br/>
                @if (IsEditMode)
                {
                    <MudCard Elevation="4" Outlined="true">
                        <MudText Typo="Typo.h3">New task</MudText>
                        <EditForm Model="@_model" OnValidSubmit="OnValidSubmit">
                            <DataAnnotationsValidator/>
                            <MudTextField Label="Task" Class="mt-3" @bind-Value="_model.Tasks"
                                          For="@(() => _model.Tasks)" InputType="InputType.Text"/>
                            <MudSelect T="int?" Label="Role" Class="mt-3" @bind-Value="_model.RoleId"
                                       For="@(() => _model.RoleId)" PopoverClass="role-select-popover">
                                <MudSelectItem T="int?" Value="null">Unassigned</MudSelectItem>
                                @foreach (Role role in roles)
                                {
                                    <MudSelectItem T="int?" Value="@role.Id">@role.Name</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                                       Class="ml-auto mt-2">
                                Create new task
                            </MudButton>
                        </EditForm>
                    </MudCard>
                }
            </div>
        }
        else
        {
            <MudText Typo="Typo.h1">Current Cue</MudText>
            <MudText>No cue selected</MudText>
        }
    }
    else
    {
        <MudText Typo="Typo.h1">Current Cue</MudText>
        <MudText>No cue selected</MudText>
    }
</GridChild>


@code
{
    [CascadingParameter(Name = "IsEditMode")]
    public bool IsEditMode { get; set; }

    [CascadingParameter]
    public ShowService? ShowService { get; set; }

    //              RoleID, IsChecked
    private Dictionary<int, bool> _roleFilters = new();

    private Cue?           _currentCue;
    private List<CueTask>? _currentTasks;
    private Action?        _showServiceStateChangedHandler;

    private readonly NewTaskModel _model = new();

    private bool? AllRolesSelected => All();

    private bool? All()
    {
        if (_roleFilters.Count > 0 && _roleFilters.Values.All(isChecked => isChecked)) return true;
        if (_roleFilters.Count > 0 && _roleFilters.Values.All(isChecked => !isChecked)) return false;
        return null;
    }

    private class NewTaskModel
    {
        [Required]
        public string Tasks { get; set; } = string.Empty;

        public int? RoleId { get; set; }
    }

    private async Task OnValidSubmit(EditContext context)
    {
        if (Auth.ApiKey is { } key)
        {
            CueTask newTask = new()
            {
                CueId  = _currentCue!.Id,
                RoleId = _model.RoleId,
                Tasks  = _model.Tasks,
            };
            _currentTasks?.Add(newTask);
            await ShowService!.SendEditModeAction(key, EditModeMethod.Create, newTask);
            _model.Tasks  = string.Empty;
            _model.RoleId = null;
        }
    }

    protected override void OnInitialized()
    {
        _showServiceStateChangedHandler =  OnShowServiceStateChanged;
        ShowService?.OnStateChanged     += _showServiceStateChangedHandler;
    }

    protected override void OnParametersSet()
    {
        if (ShowService?.Roles is { } roles)
        {
            _roleFilters = roles.ToDictionary(
                role => role.Id,
                role => _roleFilters.TryGetValue(role.Id, out bool isChecked) && isChecked);
        }
    }

    private void OnShowServiceStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_showServiceStateChangedHandler is not null)
        {
            ShowService?.OnStateChanged -= _showServiceStateChangedHandler;
        }
    }

    private Task OnAllRolesChanged(bool? value)
    {
        if (ShowService?.Roles is { } roles)
        {
            foreach (Role role in roles)
            {
                _roleFilters[role.Id] = value ?? true;
            }
        }

        return Task.CompletedTask;
    }

    private void CueTaskChanged(string newTask, CueTask cueTask)
    {
        if (Auth.ApiKey is { } key)
        {
            cueTask.Tasks = newTask;
            ShowService?.SendEditModeAction(key, EditModeMethod.Update, cueTask);
        }
    }

    private void DeleteCueTask(CueTask cueTask)
    {
        if (Auth.ApiKey is { } key)
        {
            ShowService?.SendEditModeAction(key, EditModeMethod.Delete, cueTask);
        }
    }


    private async Task DeleteAllTasksButtonPressed()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
                           "Warning",
                           "Deleting all tasks can not be undone!",
                           "Delete!", cancelText: "Cancel");

        if ((result == null ? "Canceled" : "Deleted!") != "Deleted!") return;


        if (ShowService.CurrentlyViewingShow is { Id: { } showID } && Auth.ApiKey is { } key && _currentTasks?[0] is { } firstTask)
        {
            // Need to pass a task to tell it in which show and cue
            (await ShowService.SendEditModeAction(key, EditModeMethod.DeleteAll, firstTask)).IfError(e => Dialogs.ShowError("Error deleting tasks", e));
        }
    }
}