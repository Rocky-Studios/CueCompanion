@inject ShowService ShowService

@if (ShowService?.CurrentlyViewingShow?.Id is { } showID)
{
    <MudTooltip Text="Delete">
        <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Delete"
                       OnClick="@(() => { DeleteShowButtonPressed.InvokeAsync(showID); })"/>
    </MudTooltip>
    <MudTooltip Text="Duplicate">
        <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.FileCopy"
                       OnClick="@(() => { DuplicateShowButtonPressed.InvokeAsync(showID); })"/>
    </MudTooltip>
}
else
{
    <MudTooltip Text="Delete">
        <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Delete"/>
    </MudTooltip>
    <MudTooltip Text="Duplicate">
        <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.FileCopy"/>
    </MudTooltip>
}
<MudTooltip Text="Create new">
    <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Add" OnClick="@NewShowButtonPressed"/>
</MudTooltip>
<InputFile id="@IMPORT_INPUT_ID" style="display:none;" accept=".json,application/json"
           OnChange="@OnImportFileSelected"/>
<MudTooltip Text="Import">
    <MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.FileUpload"
                   OnClick="@OnFileUploadPressed"/>
</MudTooltip>

@code
{
    private const string IMPORT_INPUT_ID = "import-show-input";

    [Parameter]
    public required EventCallback NewShowButtonPressed { get; set; }

    [Parameter]
    public required EventCallback<int> DeleteShowButtonPressed { get; set; }

    [Parameter]
    public required EventCallback<int> DuplicateShowButtonPressed { get; set; }

    [Parameter]
    public required EventCallback OnFileUploadPressed { get; set; }

    [Parameter]
    public required EventCallback<InputFileChangeEventArgs> OnImportFileSelected { get; set; }
}
